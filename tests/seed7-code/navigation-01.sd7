# anything useful.
#
# DO NOT MODIFY the code.  It is used by seed7-mode test code which expects
#                          lines to be at specific locations.

# ----------------------------------------------------------------------------
# Test Code
# ---------

$ include "seed7_05.s7i";

const func integer: add (in integer: a, in integer: b) is func
  local
    var integer: result is 0;
  begin
    result := a + b;
    return result;
  end func;

const func string: greet (in string: name) is func
  local
    var string: msg is "";
  begin
    msg := "Hello " <& name;
    return msg;
  end func;

const proc: printValue (in integer: n) is func
  begin
    writeln(n);
  end func;

